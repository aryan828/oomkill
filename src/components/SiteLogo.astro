---
/** Inline wordmark: icon on small screens, icon + text from 640px up. */
---

<span class="site-logo-slot site-logo-slot--compact" aria-hidden="true">
	<svg class="site-logo-mark" viewBox="0 0 28 32" fill="none" xmlns="http://www.w3.org/2000/svg">
		<g fill="currentColor">
			<rect x="1" y="5" width="26" height="16" rx="2" stroke="currentColor" stroke-width="2" fill="none" />
			<rect x="5" y="9" width="4" height="8" rx="0.5" />
			<rect x="11" y="9" width="4" height="8" rx="0.5" />
			<rect x="17" y="9" width="4" height="8" rx="0.5" />
			<rect x="23" y="9" width="2" height="8" rx="0.5" />
			<rect x="4" y="21" width="2.5" height="3" />
			<rect x="8" y="21" width="2.5" height="3" />
			<rect x="12" y="21" width="2.5" height="3" />
			<rect x="16" y="21" width="2.5" height="3" />
			<rect x="20" y="21" width="2.5" height="3" />
			<circle cx="24" cy="20" r="5" />
			<path
				d="M22.2 18.8h.9M24.9 18.8h.9M22.4 21.2c.5.8 1.2 1.2 1.6 1.2s1.1-.4 1.6-1.2"
