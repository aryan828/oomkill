			<circle cx="24" cy="20" r="5" />
			<path
				d="M22.2 18.8h.9M24.9 18.8h.9M22.4 21.2c.5.8 1.2 1.2 1.6 1.2s1.1-.4 1.6-1.2"
				stroke="var(--bg)"
				stroke-width="1.1"
				stroke-linecap="round"
			/>
			<path d="M23 18.3v.9M25.7 18.3v.9" stroke="var(--bg)" stroke-width="1.2" stroke-linecap="round" />
		</g>
		<text
			x="36"
