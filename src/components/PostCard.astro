---
interface Props {
	slug: string;
	title: string;
	description: string;
	pubDate: Date;
}

const { slug, title, description, pubDate } = Astro.props;
const formattedDate = pubDate.toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'short',
	day: 'numeric',
});
---

<a href={`/blog/${slug}`} class="post-row">
	<time class="post-row-date" datetime={pubDate.toISOString()}>{formattedDate}</time>
	<div>
		<h2 class="post-row-title">{title}</h2>
		<p class="post-row-desc">{description}</p>
	</div>
</a>
