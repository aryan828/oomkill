---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Not found | oomkill.dev" description="That page doesn't exist." noindex={true}>
	<section class="notfound">
		<p class="notfound-code">404</p>
		<h1 class="notfound-title">This page got OOM-killed.</h1>
		<p class="notfound-lead">
			The thing you were looking for isn't here — maybe it moved, maybe it never existed.
		</p>
		<p>
			<a href="/" class="notfound-link">← Back home</a>
			<span class="article-meta-sep">·</span>
			<a href="/blog" class="notfound-link">Browse writing</a>
		</p>
	</section>
</Layout>

<style>
	.notfound {
		padding: 2rem 0 4rem;
	}

	.notfound-code {
		font-family: var(--font-mono);
		font-size: 0.875rem;
		letter-spacing: 0.1em;
		color: var(--accent);
	}

	.notfound-title {
		margin-top: 0.75rem;
		font-size: clamp(1.75rem, 4vw, 2.25rem);
		font-weight: 600;
		letter-spacing: -0.03em;
		line-height: 1.2;
	}

	.notfound-lead {
		margin-top: 1rem;
		font-size: 1.0625rem;
		line-height: 1.65;
		color: var(--text-muted);
	}

	.notfound p:last-child {
		margin-top: 1.75rem;
		display: flex;
		gap: 0.75rem;
		align-items: center;
		font-size: 0.9375rem;
	}

	.notfound-link {
		font-weight: 500;
		color: var(--accent);
	}

	.notfound-link:hover {
		text-decoration: underline;
	}
</style>
